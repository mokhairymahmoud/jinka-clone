{
  "name": "@jinka-eg/crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "backfill:phase3": "tsx src/backfill-phase3.ts",
    "ingest": "tsx src/enqueue.ts",
    "ingest:once": "tsx src/run-once.ts",
    "launch:drill": "tsx src/launch-readiness.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "replay": "tsx src/replay.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker": "tsx src/worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@jinka-eg/config": "workspace:*",
    "@jinka-eg/types": "workspace:*",
    "bullmq": "^5.43.0",
    "crawlee": "^3.13.4",
    "ioredis": "^5.5.0",
    "minio": "^8.0.6",
    "playwright": "^1.51.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
