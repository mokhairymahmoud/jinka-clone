generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, postgis_topology, postgis_tiger_geocoder, fuzzystrmatch]
}

enum UserRole {
  USER
  OPS_REVIEWER
  ADMIN
}

enum ListingSource {
  NAWY
  PROPERTY_FINDER
  AQARMAP
  FACEBOOK
}

enum ListingPurpose {
  RENT
  SALE
}

enum MarketSegment {
  RESALE
  PRIMARY
  OFF_PLAN
}

enum FraudLabel {
  SAFE
  REVIEW
  HIGH_RISK
}

enum AreaType {
  GOVERNORATE
  CITY
  AREA
}

enum SourceListingStatus {
  ACTIVE
  MISSING
  REMOVED
  BLOCKED
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  name                String?
  locale              String             @default("en")
  role                UserRole           @default(USER)
  notificationPrefs   Json?
  otpChallenges       OtpChallenge[]
  authSessions        AuthSession[]
  alerts              Alert[]
  favorites           Favorite[]
  memberships         ShortlistMember[]
  pushSubscriptions   PushSubscription[]
  reports             Report[]
  notifications       Notification[]
  adminAuditLogs      AdminAuditLog[]
  shortlistComments   ShortlistComment[]
  shortlistItemsAdded ShortlistItem[]
  sourceBlacklists    SourceBlacklist[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model OtpChallenge {
  id          String   @id @default(cuid())
  userId      String?
  email       String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int      @default(0)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email, expiresAt])
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, expiresAt])
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dhKey   String
  authKey     String
  platform    String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Alert {
  id              String   @id @default(cuid())
  userId          String
  name            String
  locale          String   @default("en")
  filters         Json
  isPaused        Boolean  @default(false)
  snoozedUntil    DateTime?
  notifyByPush    Boolean  @default(true)
  notifyByEmail   Boolean  @default(true)
  quietHoursStart String?
  quietHoursEnd   String?
  lastMatchedAt   DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications   Notification[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  clusterId  String
  note       String?
  state      String   @default("saved")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cluster    ListingCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, clusterId])
}

model Shortlist {
  id          String            @id @default(cuid())
  name        String
  description String?
  members     ShortlistMember[]
  comments    ShortlistComment[]
  items       ShortlistItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ShortlistMember {
  id          String    @id @default(cuid())
  shortlistId String
  userId      String
  role        String    @default("owner")
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([shortlistId, userId])
}

model ShortlistComment {
  id          String    @id @default(cuid())
  shortlistId String
  authorId    String
  body        String
  listingId   String?
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model ShortlistItem {
  id          String    @id @default(cuid())
  shortlistId String
  clusterId   String
  addedById   String
  note        String?
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  cluster     ListingCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  addedBy     User      @relation(fields: [addedById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([shortlistId, clusterId])
}

model Developer {
  id          String    @id @default(cuid())
  slug        String    @unique
  nameEn      String
  nameAr      String
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Area {
  id               String                @id @default(cuid())
  slug             String                @unique
  type             AreaType              @default(AREA)
  nameEn           String
  nameAr           String
  normalizedName   String
  parentId         String?
  centroid         Unsupported("geometry(Point, 4326)")?
  geometry         Unsupported("geometry(MultiPolygon, 4326)")?
  isActive         Boolean               @default(true)
  parent           Area?                 @relation("AreaHierarchy", fields: [parentId], references: [id])
  children         Area[]                @relation("AreaHierarchy")
  aliases          AreaAlias[]
  externalMappings AreaExternalMapping[]
  projects         Project[]
  listingClusters  ListingCluster[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([type, parentId])
  @@index([normalizedName])
}

model AreaAlias {
  id              String   @id @default(cuid())
  areaId          String
  alias           String
  normalizedAlias String
  locale          String?
  area            Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([areaId, normalizedAlias])
  @@index([normalizedAlias])
}

model AreaExternalMapping {
  id               String         @id @default(cuid())
  areaId           String
  source           ListingSource
  sourceExternalId String?
  sourceSlug       String?
  sourceType       String?
  area             Area           @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([source, sourceExternalId])
  @@index([source, sourceSlug])
}

model Project {
  id               String           @id @default(cuid())
  slug             String           @unique
  nameEn           String
  nameAr           String
  developerId      String
  areaId           String
  handoffYear      Int?
  startingPrice    Int?
  paymentPlanYears Int?
  imageUrl         String?
  sourceUrls       String[]
  developer        Developer        @relation(fields: [developerId], references: [id])
  area             Area             @relation(fields: [areaId], references: [id])
  listingClusters  ListingCluster[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model RawSnapshot {
  id                 String           @id @default(cuid())
  source             ListingSource
  sourceListingId    String?
  sourceUrl          String
  payloadType        String
  storageKey         String
  parserVersion      String
  extractionCoverage Float?
  fetchedAt          DateTime         @default(now())
  listingVariants    ListingVariant[]
}

model ListingCluster {
  id               String             @id @default(cuid())
  projectId        String?
  canonicalTitleEn String
  canonicalTitleAr String
  purpose          ListingPurpose
  marketSegment    MarketSegment
  propertyType     String
  areaId           String?
  location         Unsupported("geometry(Point, 4326)")?
  bedrooms         Int?
  bathrooms        Int?
  areaSqm          Float?
  bestPrice        Int?
  currency         String             @default("EGP")
  fraudLabel       FraudLabel         @default(SAFE)
  fraudScore       Float              @default(0)
  variants         ListingVariant[]
  priceHistory     PriceHistory[]
  fraudCases       FraudCase[]
  reports          Report[]
  notifications    Notification[]
  project          Project?           @relation(fields: [projectId], references: [id])
  area             Area?              @relation(fields: [areaId], references: [id])
  favorites        Favorite[]
  shortlistItems   ShortlistItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ListingVariant {
  id                   String         @id @default(cuid())
  clusterId            String?
  rawSnapshotId        String
  source               ListingSource
  sourceListingId      String
  canonicalUrl         String
  titleEn              String
  titleAr              String
  descriptionEn        String?
  descriptionAr        String?
  purpose              ListingPurpose
  marketSegment        MarketSegment
  propertyType         String
  publishedAt          DateTime?
  extractionConfidence Float
  rawFields            Json
  imageUrls            String[]
  firstSeenAt          DateTime       @default(now())
  lastSeenAt           DateTime       @default(now())
  lastCrawledAt        DateTime       @default(now())
  refreshMissCount     Int            @default(0)
  sourceStatus         SourceListingStatus @default(ACTIVE)
  inactiveAt           DateTime?
  cluster              ListingCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  rawSnapshot          RawSnapshot     @relation(fields: [rawSnapshotId], references: [id], onDelete: Cascade)
  priceHistory         PriceHistory[]
  partitionMemberships SourcePartitionListing[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([source, sourceListingId])
  @@index([source, inactiveAt, lastSeenAt])
}

model PriceHistory {
  id             String          @id @default(cuid())
  clusterId      String?
  variantId      String?
  price          Int
  currency       String          @default("EGP")
  recordedAt     DateTime        @default(now())
  cluster        ListingCluster? @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  variant        ListingVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model ClusterEdge {
  id             String   @id @default(cuid())
  leftVariantId  String
  rightVariantId String
  score          Float
  reasons        Json
  createdAt      DateTime @default(now())

  @@unique([leftVariantId, rightVariantId])
}

model FraudCase {
  id                 String          @id @default(cuid())
  clusterId          String
  label              FraudLabel
  score              Float
  explanation        Json
  operatorOverride   FraudLabel?
  resolvedAt         DateTime?
  cluster            ListingCluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
}

model Report {
  id          String          @id @default(cuid())
  userId      String
  clusterId   String
  reason      String
  details     String?
  resolvedAt  DateTime?
  resolutionNote String?
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cluster     ListingCluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
}

model SourcePartition {
  id             String        @id @default(cuid())
  source         ListingSource
  label          String
  seedUrl        String
  purpose        ListingPurpose?
  marketSegment  MarketSegment?
  propertyType   String?
  areaSlug       String?
  page           Int?
  priority       Int           @default(100)
  isActive       Boolean       @default(true)
  failureCount   Int           @default(0)
  lastPageCrawled Int?
  lastDiscoverySignature String?
  stopReason     String?
  lastCrawledAt  DateTime?
  nextCrawlAt    DateTime      @default(now())
  listings       SourcePartitionListing[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([source, label])
  @@index([source, isActive, nextCrawlAt])
}

model SourcePartitionListing {
  id              String         @id @default(cuid())
  partitionId     String
  variantId       String?
  sourceListingId String
  lastSweepToken  String?
  missCount       Int            @default(0)
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  partition       SourcePartition @relation(fields: [partitionId], references: [id], onDelete: Cascade)
  variant         ListingVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([partitionId, sourceListingId])
  @@index([partitionId, lastSweepToken, missCount])
}

model IngestionRun {
  id               String        @id @default(cuid())
  source           ListingSource
  status           String
  discoveredCount  Int           @default(0)
  parsedCount      Int           @default(0)
  failedCount      Int           @default(0)
  extractionRate   Float?
  startedAt        DateTime      @default(now())
  completedAt      DateTime?
  parserDriftAlarms ParserDriftAlarm[]
}

model ConnectorControl {
  id             String        @id @default(cuid())
  source         ListingSource @unique
  isEnabled      Boolean       @default(true)
  disabledReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model SourceBlacklist {
  id          String        @id @default(cuid())
  source      ListingSource
  matchType   String
  value       String
  reason      String?
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@unique([source, matchType, value])
}

model ParserDriftAlarm {
  id             String        @id @default(cuid())
  source         ListingSource
  ingestionRunId String
  severity       String
  message        String
  threshold      Float
  details        Json?
  resolvedAt     DateTime?
  ingestionRun   IngestionRun  @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Notification {
  id               String                 @id @default(cuid())
  userId           String
  alertId          String?
  clusterId        String?
  type             String
  title            String
  body             String
  dedupeKey        String                 @unique
  readAt           DateTime?
  metadata         Json?
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert            Alert?                 @relation(fields: [alertId], references: [id], onDelete: SetNull)
  cluster          ListingCluster?        @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  deliveries       NotificationDelivery[]
  createdAt        DateTime               @default(now())

  @@index([userId, createdAt])
}

model NotificationDelivery {
  id             String        @id @default(cuid())
  notificationId String
  channel        String
  status         String
  metadata       Json?
  attemptedAt    DateTime?
  deliveredAt    DateTime?
  notification   Notification  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@index([notificationId, channel])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entityType  String
  entityId    String
  beforeState Json?
  afterState  Json?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
