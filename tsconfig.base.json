{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@jinka-eg/types": ["packages/types/src"],
      "@jinka-eg/ui": ["packages/ui/src"],
      "@jinka-eg/config": ["packages/config/src"],
      "@jinka-eg/fixtures": ["packages/fixtures/src"]
    }
  }
}
