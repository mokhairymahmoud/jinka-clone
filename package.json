{
  "name": "jinka-eg-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @jinka-eg/api prisma:generate",
    "db:migrate": "pnpm --filter @jinka-eg/api prisma:migrate",
    "db:studio": "pnpm --filter @jinka-eg/api prisma:studio"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
