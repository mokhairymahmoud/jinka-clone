meta {
  name: 11 Create Favorite
  type: http
  seq: 11
}

post {
  url: {{webBaseUrl}}/api/favorites
  body: json
  auth: none
}

headers {
  cookie: access_token={{accessToken}}; refresh_token={{refreshToken}}
  content-type: application/json
  accept: application/json
}

body:json {
  {
    "clusterId": "{{clusterId}}",
    "note": "Created from Bruno via web proxy"
  }
}

tests {
  const body = res.body;

  if (body?.id) {
    bru.setEnvVar("favoriteId", body.id);
  }
}
