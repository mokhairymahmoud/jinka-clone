meta {
  name: 20 Admin Split Cluster
  type: http
  seq: 20
}

post {
  url: {{webBaseUrl}}/api/admin/clusters/{{clusterId}}/split
  body: json
  auth: none
}

headers {
  cookie: access_token={{accessToken}}; refresh_token={{refreshToken}}
  content-type: application/json
  accept: application/json
}

body:json {
  {
    "variantIds": ["{{variantId}}"]
  }
}
