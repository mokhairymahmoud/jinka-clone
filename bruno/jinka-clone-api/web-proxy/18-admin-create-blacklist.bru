meta {
  name: 18 Admin Create Blacklist
  type: http
  seq: 18
}

post {
  url: {{webBaseUrl}}/api/admin/blacklists
  body: json
  auth: none
}

headers {
  cookie: access_token={{accessToken}}; refresh_token={{refreshToken}}
  content-type: application/json
  accept: application/json
}

body:json {
  {
    "source": "manual",
    "matchType": "contains",
    "value": "spam.example.com",
    "reason": "Created from Bruno web proxy"
  }
}
