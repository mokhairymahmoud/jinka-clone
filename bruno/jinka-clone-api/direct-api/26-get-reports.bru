meta {
  name: 26 Get Reports
  type: http
  seq: 26
}

get {
  url: {{apiBaseUrl}}/v1/reports
  body: none
  auth: none
}

headers {
  authorization: Bearer {{accessToken}}
  accept: application/json
}

tests {
  const body = res.body;

  if (Array.isArray(body) && body[0]?.id) {
    bru.setEnvVar("reportId", body[0].id);
  }
}
