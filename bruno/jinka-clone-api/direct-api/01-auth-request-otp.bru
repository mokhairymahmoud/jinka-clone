meta {
  name: 01 Auth Request OTP
  type: http
  seq: 1
}

post {
  url: {{apiBaseUrl}}/v1/auth/email/request-otp
  body: json
  auth: none
}

headers {
  content-type: application/json
  accept: application/json
}

body:json {
  {
    "email": "{{userEmail}}"
  }
}

tests {
  const body = res.body;

  test("status is not 5xx", function() {
    expect(res.status).to.be.lessThan(500);
  });

  if (body?.otpPreview) {
    bru.setEnvVar("otpCode", body.otpPreview);
  }
}
