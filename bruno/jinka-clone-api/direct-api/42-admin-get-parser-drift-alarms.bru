meta {
  name: 42 Admin Get Parser Drift Alarms
  type: http
  seq: 42
}

get {
  url: {{apiBaseUrl}}/v1/admin/parser-drift-alarms
  body: none
  auth: none
}

headers {
  authorization: Bearer {{accessToken}}
  accept: application/json
}

tests {
  const body = res.body;

  if (Array.isArray(body) && body[0]?.id) {
    bru.setEnvVar("parserDriftAlarmId", body[0].id);
  }
}
