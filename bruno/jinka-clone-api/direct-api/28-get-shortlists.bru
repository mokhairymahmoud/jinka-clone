meta {
  name: 28 Get Shortlists
  type: http
  seq: 28
}

get {
  url: {{apiBaseUrl}}/v1/shortlists
  body: none
  auth: none
}

headers {
  authorization: Bearer {{accessToken}}
  accept: application/json
}

tests {
  const body = res.body;

  if (Array.isArray(body) && body[0]?.id) {
    bru.setEnvVar("shortlistId", body[0].id);
  }
}
