meta {
  name: 38 Admin Get Fraud Cases
  type: http
  seq: 40
}

get {
  url: {{apiBaseUrl}}/v1/admin/fraud-cases
  body: none
  auth: none
}

headers {
  authorization: Bearer {{accessToken}}
  accept: application/json
}

tests {
  const body = res.body;
  
  if (Array.isArray(body) && body[0]?.id) {
    bru.setEnvVar("fraudCaseId", body[0].id);
  }
}
