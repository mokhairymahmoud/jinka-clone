meta {
  name: 21 Patch Alert
  type: http
  seq: 23
}

patch {
  url: {{apiBaseUrl}}/v1/alerts/{{alertId}}
  body: json
  auth: none
}

headers {
  authorization: Bearer {{accessToken}}
  content-type: application/json
  accept: application/json
}

body:json {
  {
    "name": "Bruno Alert Updated",
    "filters": {
      "query": "{{listingQuery}}",
      "purpose": "sale",
      "marketSegment": "resale",
      "propertyTypes": ["apartment"],
      "sort": "newest"
    }
  }
}
