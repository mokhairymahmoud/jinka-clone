meta {
  name: 34 Admin Get Connectors
  type: http
  seq: 36
}

get {
  url: {{apiBaseUrl}}/v1/admin/connectors
  body: none
  auth: none
}

headers {
  authorization: Bearer {{accessToken}}
  accept: application/json
}

tests {
  const body = res.body;
  
  if (Array.isArray(body) && body[0]?.source) {
    bru.setEnvVar("connectorSource", body[0].source);
  }
}
